{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "src/scripts"
  ]
}