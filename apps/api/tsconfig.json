{
  "compilerOptions": {

    "target": "ES2020",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "types": ["node"],

    "outDir": "dist",

    "rootDir": "src",

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "strict": false,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true

  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "src/scripts"
  ]
}